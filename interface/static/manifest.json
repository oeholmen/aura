{
  "id": "/aura",
  "name": "Aura — Autonomy Engine",
  "short_name": "Aura",
  "description": "Your Sovereign Digital Companion. Voice-enabled AGI assistant with neural stream, autonomous cognition, and real-time communication.",
  "start_url": "/?source=pwa",
  "scope": "/",
  "display": "standalone",
  "display_override": [
    "standalone",
    "minimal-ui"
  ],
  "orientation": "portrait",
  "background_color": "#030005",
  "theme_color": "#0a0a0a",
  "categories": [
    "productivity",
    "utilities",
    "social"
  ],
  "dir": "ltr",
  "lang": "en-US",
  "icons": [
    {
      "src": "/static/icon.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "any"
    },
    {
      "src": "/static/icon.svg",
      "sizes": "512x512",
      "type": "image/svg+xml",
      "purpose": "maskable"
    },
    {
      "src": "/static/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/static/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    }
  ],
  "shortcuts": [
    {
      "name": "Chat with Aura",
      "short_name": "Chat",
      "url": "/?tab=chat",
      "description": "Open the communications portal",
      "icons": [
        {
          "src": "/static/icon.svg",
          "sizes": "any"
        }
      ]
    },
    {
      "name": "Neural Stream",
      "short_name": "Stream",
      "url": "/?tab=stream",
      "description": "Watch Aura's live thought stream",
      "icons": [
        {
          "src": "/static/icon.svg",
          "sizes": "any"
        }
      ]
    }
  ],
  "share_target": {
    "action": "/?share=true",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "handle_links": "preferred",
  "launch_handler": {
    "client_mode": "focus-existing"
  },
  "prefer_related_applications": false
}